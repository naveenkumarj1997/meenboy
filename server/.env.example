PORT=5000
NODE_ENV=production

# Database Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/meenboy?retryWrites=true&w=majority

# Security
JWT_SECRET=replace-with-a-very-long-secure-random-string
JWT_EXPIRES_IN=7d

# Frontend URL (For CORS - Replace with your Vercel URL)
CLIENT_URL=https://your-vercel-app-name.vercel.app
